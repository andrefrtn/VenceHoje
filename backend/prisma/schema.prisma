generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())

  name      String
  cpf       String   @unique

  email     String   @unique
  password  String

  phone String?

  birthDate DateTime? 

  createdAt DateTime @default(now())

  contas    Conta[]
}

model Conta {
  id          Int      @id @default(autoincrement())

  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  descricao   String
  valor       Float
  vencimento  DateTime
  categoria   String?
  pago        Boolean  @default(false)
  pagoEm      DateTime?

  createdAt   DateTime @default(now())
}
