generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())

  name      String
  cpf       String   @unique

  email     String   @unique
  password  String

  phone String?

  birthDate DateTime?

  createdAt DateTime @default(now())

  contas    Conta[]

  infos     UserInfo?
}

model Conta {
  id          Int      @id @default(autoincrement())

  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  descricao   String
  valor       Float
  vencimento  DateTime
  categoria   String?
  pago        Boolean  @default(false)
  pagoEm      DateTime?

  createdAt   DateTime @default(now())
}


model UserInfo {
  id                Int      @id @default(autoincrement())

  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  salario           Float?
  rendaExtra        Float?
  gastosFixos       Float?
  gastosVariaveis   Float?
  aluguel           Float?
  financiamento     Float?
  cartao            Float?

  dependentes       Int?

  objetivo          String?
  reserva           String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}